@using EventEase.Models

<div class="event-card">
    <div class="event-card-header">
        <h3 class="event-name">@Event.Name</h3>
        <span class="event-availability @GetAvailabilityClass()">
            @GetAvailabilityText()
        </span>
    </div>
    <div class="event-card-body">
        <div class="event-info">
            <div class="info-item">
                <span class="bi bi-calendar-event"></span>
                <span>@Event.Date.ToString("MMMM dd, yyyy")</span>
            </div>
            <div class="info-item">
                <span class="bi bi-clock"></span>
                <span>@Event.Date.ToString("h:mm tt")</span>
            </div>
            <div class="info-item">
                <span class="bi bi-geo-alt"></span>
                <span>@Event.Location</span>
            </div>
            <div class="info-item">
                <span class="bi bi-people"></span>
                <span>@Event.RegisteredAttendees / @Event.Capacity attendees</span>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Event.Description))
        {
            <p class="event-description">@Event.Description</p>
        }
    </div>
    <div class="event-card-footer">
        <a href="@($"/event/{Event.Id}")" class="btn btn-primary">View Details</a>
        @if (ShowRegisterButton && IsAvailable())
        {
            <a href="@($"/register/{Event.Id}")" class="btn btn-success">Register Now</a>
        }
        else if (ShowRegisterButton)
        {
            <button class="btn btn-secondary" disabled>Fully Booked</button>
        }
    </div>
</div>

@code {
    [Parameter]
    public Event Event { get; set; } = new Event();

    [Parameter]
    public bool ShowRegisterButton { get; set; } = true;

    private bool IsAvailable()
    {
        return Event.RegisteredAttendees < Event.Capacity;
    }

    private string GetAvailabilityClass()
    {
        var spotsLeft = Event.Capacity - Event.RegisteredAttendees;
        if (spotsLeft == 0) return "fully-booked";
        if (spotsLeft <= Event.Capacity * 0.1) return "limited";
        return "available";
    }

    private string GetAvailabilityText()
    {
        var spotsLeft = Event.Capacity - Event.RegisteredAttendees;
        if (spotsLeft == 0) return "Fully Booked";
        if (spotsLeft <= Event.Capacity * 0.1) return $"Only {spotsLeft} spots left!";
        return $"{spotsLeft} spots available";
    }
}
