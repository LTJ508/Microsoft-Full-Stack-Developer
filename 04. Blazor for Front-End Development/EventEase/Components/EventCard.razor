@using EventEase.Models

@if (Event == null || !Event.IsValid())
{
    <div class="event-card event-card-error">
        <div class="alert alert-warning mb-0">
            <span class="bi bi-exclamation-triangle me-2"></span>
            <strong>Invalid Event Data</strong>
        </div>
    </div>
}
else
{
    <div class="event-card @(Event.IsPastEvent() ? "past-event" : "")">
        <div class="event-card-header">
            <h3 class="event-name">@GetSafeEventName()</h3>
            <span class="event-availability @GetAvailabilityClass()">
                @GetAvailabilityText()
            </span>
        </div>
        <div class="event-card-body">
            <div class="event-info">
                <div class="info-item">
                    <span class="bi bi-calendar-event"></span>
                    <span>@GetFormattedDate()</span>
                </div>
                <div class="info-item">
                    <span class="bi bi-clock"></span>
                    <span>@GetFormattedTime()</span>
                </div>
                <div class="info-item">
                    <span class="bi bi-geo-alt"></span>
                    <span>@GetSafeLocation()</span>
                </div>
                <div class="info-item">
                    <span class="bi bi-people"></span>
                    <span>@GetAttendeeInfo()</span>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Event.Description))
            {
                <p class="event-description">@Event.Description</p>
            }
            @if (Event.IsPastEvent())
            {
                <div class="alert alert-info mt-2 mb-0">
                    <small><span class="bi bi-info-circle me-1"></span>This event has already occurred</small>
                </div>
            }
        </div>
        <div class="event-card-footer">
            <a href="@GetEventDetailUrl()" class="btn btn-primary">View Details</a>
            @if (ShowRegisterButton && !Event.IsPastEvent())
            {
                @if (IsAvailable())
                {
                    <a href="@GetRegistrationUrl()" class="btn btn-success">Register Now</a>
                }
                else
                {
                    <button class="btn btn-secondary" disabled>Fully Booked</button>
                }
            }
        </div>
    </div>
}

@code {
    [Parameter]
    [EditorRequired]
    public Event? Event { get; set; }

    [Parameter]
    public bool ShowRegisterButton { get; set; } = true;

    protected override bool ShouldRender()
    {
        // Only re-render if Event data has changed
        return base.ShouldRender();
    }

    private bool IsAvailable()
    {
        if (Event == null) return false;
        return Event.RegisteredAttendees < Event.Capacity && !Event.IsPastEvent();
    }

    private string GetAvailabilityClass()
    {
        if (Event == null) return "unknown";
        
        var spotsLeft = Math.Max(0, Event.Capacity - Event.RegisteredAttendees);
        if (spotsLeft == 0 || Event.IsPastEvent()) return "fully-booked";
        if (spotsLeft <= Event.Capacity * 0.1) return "limited";
        return "available";
    }

    private string GetAvailabilityText()
    {
        if (Event == null) return "Unknown";
        
        if (Event.IsPastEvent()) return "Event Ended";
        
        var spotsLeft = Math.Max(0, Event.Capacity - Event.RegisteredAttendees);
        if (spotsLeft == 0) return "Fully Booked";
        if (spotsLeft <= Event.Capacity * 0.1) return $"Only {spotsLeft} spots left!";
        return $"{spotsLeft} spots available";
    }

    private string GetSafeEventName()
    {
        return string.IsNullOrWhiteSpace(Event?.Name) ? "Untitled Event" : Event.Name;
    }

    private string GetSafeLocation()
    {
        return string.IsNullOrWhiteSpace(Event?.Location) ? "Location TBD" : Event.Location;
    }

    private string GetFormattedDate()
    {
        try
        {
            return Event?.Date.ToString("MMMM dd, yyyy") ?? "Date TBD";
        }
        catch
        {
            return "Date TBD";
        }
    }

    private string GetFormattedTime()
    {
        try
        {
            return Event?.Date.ToString("h:mm tt") ?? "Time TBD";
        }
        catch
        {
            return "Time TBD";
        }
    }

    private string GetAttendeeInfo()
    {
        if (Event == null) return "N/A";
        var registered = Math.Max(0, Event.RegisteredAttendees);
        var capacity = Math.Max(1, Event.Capacity);
        return $"{registered} / {capacity} attendees";
    }

    private string GetEventDetailUrl()
    {
        return Event?.Id > 0 ? $"/event/{Event.Id}" : "/events";
    }

    private string GetRegistrationUrl()
    {
        return Event?.Id > 0 ? $"/register/{Event.Id}" : "/events";
    }
}
