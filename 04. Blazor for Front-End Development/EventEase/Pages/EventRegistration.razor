@page "/register/{id:int}"
@using EventEase.Models
@using EventEase.Services
@inject EventService EventService
@inject NavigationManager NavigationManager

<PageTitle>Register - @(selectedEvent?.Name ?? "Event") - EventEase</PageTitle>

<div class="registration-page">
    @if (!string.IsNullOrEmpty(errorLoadingMessage) || (selectedEvent == null && !isLoading))
    {
        <div class="alert alert-danger">
            <h4><span class="bi bi-exclamation-triangle me-2"></span>Event Not Found</h4>
            <p>@(errorLoadingMessage ?? "The event you're trying to register for doesn't exist or has been removed.")</p>
            <a href="/events" class="btn btn-primary">Back to Events</a>
        </div>
    }
    else if (isLoading)
    {
        <div class="loading-spinner">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading registration form...</span>
            </div>
            <p>Loading registration form...</p>
        </div>
    }
    else if (registrationSuccess)
    {
        <div class="success-message">
            <div class="success-icon">
                <span class="bi bi-check-circle-fill"></span>
            </div>
            <h2>Registration Successful!</h2>
            <p class="lead">You're all set for <strong>@selectedEvent!.Name</strong></p>
            <div class="success-details">
                <p><strong>Date:</strong> @selectedEvent.Date.ToString("MMMM dd, yyyy")</p>
                <p><strong>Time:</strong> @selectedEvent.Date.ToString("h:mm tt")</p>
                <p><strong>Location:</strong> @selectedEvent.Location</p>
            </div>
            <p class="confirmation-note">A confirmation email has been sent to <strong>@registrationModel.Email</strong></p>
            <div class="success-actions">
                <a href="/events" class="btn btn-primary btn-lg">Browse More Events</a>
                <a href="/event/@Id" class="btn btn-outline-primary btn-lg">View Event Details</a>
            </div>
        </div>
    }
    else
    {
        <div class="registration-container">
            <div class="breadcrumb-nav">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item"><a href="/events">Events</a></li>
                        <li class="breadcrumb-item"><a href="/event/@Id">@selectedEvent!.Name</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Register</li>
                    </ol>
                </nav>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <div class="registration-form-card">
                        <h2>Event Registration</h2>
                        <p class="text-muted mb-4">Complete the form below to register for this event</p>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                @errorMessage
                                <button type="button" class="btn-close" @onclick="ClearError"></button>
                            </div>
                        }

                        @if (!EventService.HasAvailableSpots(selectedEvent) || selectedEvent.IsPastEvent())
                        {
                            <div class="alert alert-warning">
                                <h4>
                                    @if (selectedEvent.IsPastEvent())
                                    {
                                        <span>Event Has Ended</span>
                                    }
                                    else
                                    {
                                        <span>Event is Fully Booked</span>
                                    }
                                </h4>
                                <p>
                                    @if (selectedEvent.IsPastEvent())
                                    {
                                        <span>This event has already occurred. Registration is no longer available.</span>
                                    }
                                    else
                                    {
                                        <span>Unfortunately, this event has reached maximum capacity. Registration is no longer available.</span>
                                    }
                                </p>
                                <a href="/events" class="btn btn-primary">Find Other Events</a>
                            </div>
                        }
                        else
                        {
                            <EditForm Model="@registrationModel" OnValidSubmit="HandleRegistration">
                                <DataAnnotationsValidator />

                                <div class="mb-3">
                                    <label for="fullName" class="form-label">Full Name *</label>
                                    <InputText id="fullName" class="form-control" @bind-Value="registrationModel.FullName" placeholder="Enter your full name" />
                                    <ValidationMessage For="@(() => registrationModel.FullName)" />
                                </div>

                                <div class="mb-3">
                                    <label for="email" class="form-label">Email Address *</label>
                                    <InputText id="email" type="email" class="form-control" @bind-Value="registrationModel.Email" placeholder="your.email@example.com" />
                                    <ValidationMessage For="@(() => registrationModel.Email)" />
                                </div>

                                <div class="mb-3">
                                    <label for="phone" class="form-label">Phone Number</label>
                                    <InputText id="phone" class="form-control" @bind-Value="registrationModel.Phone" placeholder="(123) 456-7890" />
                                    <ValidationMessage For="@(() => registrationModel.Phone)" />
                                </div>

                                <div class="mb-3">
                                    <label for="company" class="form-label">Company/Organization</label>
                                    <InputText id="company" class="form-control" @bind-Value="registrationModel.Company" placeholder="Optional" />
                                    <ValidationMessage For="@(() => registrationModel.Company)" />
                                </div>

                                <div class="mb-4">
                                    <label for="specialRequests" class="form-label">Special Requests or Dietary Restrictions</label>
                                    <InputTextArea id="specialRequests" class="form-control" rows="3" @bind-Value="registrationModel.SpecialRequests" placeholder="Let us know if you have any special needs..." />
                                    <ValidationMessage For="@(() => registrationModel.SpecialRequests)" />
                                </div>

                                <div class="form-check mb-4">
                                    <InputCheckbox id="agreeTerms" class="form-check-input" @bind-Value="registrationModel.AgreeToTerms" />
                                    <label class="form-check-label" for="agreeTerms">
                                        I agree to the event terms and conditions *
                                    </label>
                                    <ValidationMessage For="@(() => registrationModel.AgreeToTerms)" />
                                </div>

                                <div class="form-actions">
                                    <button type="submit" class="btn btn-success btn-lg" disabled="@isSubmitting">
                                        @if (isSubmitting)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                            <span>Processing...</span>
                                        }
                                        else
                                        {
                                            <span class="bi bi-check-circle me-2"></span>
                                            <span>Complete Registration</span>
                                        }
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="NavigateBack" disabled="@isSubmitting">
                                        Cancel
                                    </button>
                                </div>
                            </EditForm>
                        }
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="event-summary-card">
                        <h4>Event Summary</h4>
                        <div class="summary-content">
                            <h5 class="event-name">@selectedEvent.Name</h5>
                            
                            <div class="summary-item">
                                <span class="bi bi-calendar-event"></span>
                                <div>
                                    <small>Date</small>
                                    <p>@selectedEvent.Date.ToString("MMMM dd, yyyy")</p>
                                </div>
                            </div>

                            <div class="summary-item">
                                <span class="bi bi-clock"></span>
                                <div>
                                    <small>Time</small>
                                    <p>@selectedEvent.Date.ToString("h:mm tt")</p>
                                </div>
                            </div>

                            <div class="summary-item">
                                <span class="bi bi-geo-alt"></span>
                                <div>
                                    <small>Location</small>
                                    <p>@selectedEvent.Location</p>
                                </div>
                            </div>

                            <div class="summary-item">
                                <span class="bi bi-people"></span>
                                <div>
                                    <small>Availability</small>
                                    <p>@EventService.GetAvailableSpots(selectedEvent) spots remaining</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Event? selectedEvent;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool registrationSuccess = false;
    private string errorMessage = string.Empty;
    private string? errorLoadingMessage;

    private RegistrationModel registrationModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadEventDetails();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reload when route parameters change
        if (Id > 0 && !registrationSuccess)
        {
            await LoadEventDetails();
        }
    }

    private async Task LoadEventDetails()
    {
        isLoading = true;
        errorLoadingMessage = null;
        
        try
        {
            // Validate ID
            if (Id <= 0)
            {
                errorLoadingMessage = "Invalid event ID provided.";
                selectedEvent = null;
                return;
            }

            selectedEvent = await EventService.GetEventByIdAsync(Id);
            
            if (selectedEvent == null)
            {
                errorLoadingMessage = $"Event with ID {Id} was not found.";
            }
            else if (!selectedEvent.IsValid())
            {
                errorLoadingMessage = "Event data is invalid or corrupted.";
                selectedEvent = null;
            }
        }
        catch (Exception ex)
        {
            errorLoadingMessage = $"An error occurred while loading event details: {ex.Message}";
            selectedEvent = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleRegistration()
    {
        // Clear previous errors
        errorMessage = string.Empty;

        // Validate event still exists and is available
        if (selectedEvent == null)
        {
            errorMessage = "Event information is not available.";
            return;
        }

        if (!selectedEvent.IsValid())
        {
            errorMessage = "Event data is invalid.";
            return;
        }

        if (selectedEvent.IsPastEvent())
        {
            errorMessage = "This event has already occurred. Registration is no longer available.";
            return;
        }

        if (!EventService.HasAvailableSpots(selectedEvent))
        {
            errorMessage = "This event is now fully booked. Registration is no longer available.";
            return;
        }

        // Validate form data
        if (string.IsNullOrWhiteSpace(registrationModel.FullName))
        {
            errorMessage = "Please enter your full name.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registrationModel.Email))
        {
            errorMessage = "Please enter your email address.";
            return;
        }

        if (!registrationModel.AgreeToTerms)
        {
            errorMessage = "You must agree to the terms and conditions to register.";
            return;
        }

        isSubmitting = true;

        try
        {
            // Simulate API delay
            await Task.Delay(1500);

            var success = await EventService.RegisterForEventAsync(
                Id, 
                registrationModel.FullName, 
                registrationModel.Email
            );

            if (success)
            {
                registrationSuccess = true;
            }
            else
            {
                errorMessage = "Registration failed. The event may be fully booked. Please try again or contact support.";
            }
        }
        catch (ArgumentException argEx)
        {
            errorMessage = $"Invalid input: {argEx.Message}";
        }
        catch (InvalidOperationException opEx)
        {
            errorMessage = $"Registration error: {opEx.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred during registration. Please try again later. Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void NavigateBack()
    {
        if (selectedEvent?.Id > 0)
        {
            NavigationManager.NavigateTo($"/event/{selectedEvent.Id}");
        }
        else
        {
            NavigationManager.NavigateTo("/events");
        }
    }

    private void ClearError()
    {
        errorMessage = string.Empty;
    }
}
